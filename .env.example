# Copy to `.env` and fill in. Loaded automatically by src/module/llm.py.
# Three keys are required for a full pipeline run:
#   MISTRAL_API_KEY    — page OCR (markdown + figure extraction), the front-end
#   OPENROUTER_API_KEY — the correction pass (Qwen3-VL proofreads each page vs its image)
#   DEEPSEEK_API_KEY   — text nodes (extractor, seam, refiner, governor, entity grouping/attribution)
MISTRAL_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
DEEPSEEK_API_KEY=sk-...

# Optional overrides (defaults shown):
# TEXT_MODEL=deepseek/deepseek-v4-flash
# CORRECTOR_MODEL=openrouter/qwen/qwen3-vl-235b-a22b-instruct
# CORRECTOR_PROVIDER=DeepInfra
