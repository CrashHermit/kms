# Copy to `.env` and fill in. Loaded automatically by src/kms/core/llm.py.
# Three keys are required for a full pipeline run:
#   MISTRAL_API_KEY    — page OCR (markdown + figure extraction), the front-end
#   OPENROUTER_API_KEY — the correction pass (Qwen3-VL proofreads each page vs its image)
#   DEEPSEEK_API_KEY   — text nodes (extractor, seam, splitter, finders, attributors, distributor)
MISTRAL_API_KEY=
OPENROUTER_API_KEY=sk-or-
DEEPSEEK_API_KEY=sk-

# Optional model overrides (defaults shown):
# TEXT_MODEL=deepseek/deepseek-v4-flash
# CORRECTOR_MODEL=openrouter/qwen/qwen3-vl-235b-a22b-instruct
# CORRECTOR_PROVIDER=DeepInfra

# --- Graph tier (Neo4j) ---
# The durable graph the graph tier reads and writes. Same four values whether you point at
# Aura (neo4j+s://…) or a self-hosted instance (bolt://…).
# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=...
# NEO4J_DATABASE=neo4j
