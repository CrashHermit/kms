# Copy to `.env` and fill in. Loaded automatically by src/module/llm.py.
# Both keys are required for a full pipeline run:
#   DEEPSEEK_API_KEY   — text nodes (extractor, seam, refiner, governor, entity grouping/attribution)
#   OPENROUTER_API_KEY — vision nodes (OCR, image filter)
DEEPSEEK_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Optional — only for the Mistral OCR front-end (run(..., frontend="mistral")).
# An API alternative to the local docling + vision-OCR ingestion path; no GPU needed.
# MISTRAL_API_KEY=...

# Optional overrides (defaults shown):
# TEXT_MODEL=deepseek/deepseek-v4-flash
# VISION_MODEL=openrouter/qwen/qwen3-vl-235b-a22b-instruct
# VISION_PROVIDER=DeepInfra
